    "eject": "react-scripts eject",
    "copy-cesium": "node -e \"const fs=require('fs');const path=require('path');const src=path.join(__dirname,'node_modules/cesium/Build/Cesium');const dest=path.join(__dirname,'public/Cesium');if(fs.existsSync(dest))fs.rmSync(dest,{recursive:true});fs.cpSync(src,dest,{recursive:true});console.log('Cesium copied to public/Cesium');\""
